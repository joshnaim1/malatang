# Fireworks (Judge commentary + Reflection)
FIREWORKS_API_KEY=fw_xxx
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_MODEL=accounts/fireworks/models/<pick-from-current-catalog>
FIREWORKS_TIMEOUT_S=600

# Self-hosted Creator in AMD AI Notebooks (Radeon Pro W7900, vLLM on same box)
VLLM_BASE_URL=http://localhost:8090/v1
VLLM_API_KEY=<random-string-you-set-when-launching-vllm>
CREATOR_MODEL=Qwen/Qwen2.5-Coder-7B-Instruct

# Hugging Face (model downloads in the notebook)
HF_TOKEN=hf_xxx

# Runner config
BENCHMARK_ATTEMPTS_PER_BUG=8
BENCHMARK_TEMPERATURE=0.8
SANDBOX_TIMEOUT_S=120
